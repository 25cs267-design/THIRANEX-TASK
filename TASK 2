/* =========================
   CSS VARIABLES
========================= */

:root {
    --bg-color: #ffffff;
    --text-color: #222222;
    --card-bg: #f5f5f5;
    --primary: #2563eb;
    --secondary: #1e40af;
    --shadow: 0 4px 15px rgba(0,0,0,0.1);
}

/* Dark Theme */

[data-theme="dark"] {
    --bg-color: #121212;
    --text-color: #f5f5f5;
    --card-bg: #1f1f1f;
    --primary: #60a5fa;
    --secondary: #3b82f6;
    --shadow: 0 4px 15px rgba(255,255,255,0.1);
}

/* =========================
   GLOBAL RESET
========================= */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, sans-serif;
    background: var(--bg-color);
    color: var(--text-color);
    transition: 0.3s ease;
    line-height: 1.6;
}

/* =========================
   HEADER
========================= */

header {
    background: var(--primary);
    color: white;
    padding: 1rem;
}

.header-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    list-style: none;
}

nav a {
    color: white;
    text-decoration: none;
    font-weight: bold;
}

.theme-btn {
    background: white;
    color: var(--primary);
    border: none;
    padding: 10px 15px;
    cursor: pointer;
    border-radius: 5px;
}

/* =========================
   HERO SECTION
========================= */

.hero {
    display: grid;
    gap: 2rem;
    padding: 2rem;
    text-align: center;
}

.hero img {
    width: 220px;
    margin: auto;
    border-radius: 50%;
    box-shadow: var(--shadow);
}

.hero-content h2 {
    color: var(--primary);
}

/* =========================
   SKILLS
========================= */

.skills {
    padding: 2rem;
}

.skills-grid {
    display: grid;
    gap: 1rem;
}

.skill-card {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 10px;
    box-shadow: var(--shadow);
    transition: 0.3s;
}

.skill-card:hover {
    transform: translateY(-5px);
}

/* =========================
   PROJECTS
========================= */

.projects {
    padding: 2rem;
}

.project-grid {
    display: grid;
    gap: 1.5rem;
}

.project-card {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 10px;
    box-shadow: var(--shadow);
}

/* =========================
   CONTACT
========================= */

.contact {
    padding: 2rem;
}

.contact form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

input,
textarea {
    padding: 12px;
    border: 1px solid #ccc;
    border-radius: 6px;
}

button {
    padding: 12px;
    border: none;
    background: var(--primary);
    color: white;
    cursor: pointer;
    border-radius: 6px;
}

button:hover {
    background: var(--secondary);
}

/* =========================
   FOOTER
========================= */

footer {
    text-align: center;
    padding: 1rem;
    background: var(--primary);
    color: white;
}

/* =========================
   TABLET
========================= */

@media (min-width: 768px) {

    .header-container {
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
    }

    .hero {
        grid-template-columns: 1fr 1fr;
        align-items: center;
        text-align: left;
    }

    .skills-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .project-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

/* =========================
   DESKTOP
========================= */

@media (min-width: 1024px) {

    .skills-grid {
        grid-template-columns: repeat(4, 1fr);
    }

    .project-grid {
        grid-template-columns: repeat(3, 1fr);
    }

    .hero {
        max-width: 1200px;
        margin: auto;
    }
}
const themeToggle = document.getElementById("themeToggle");

themeToggle.addEventListener("click", () => {

    const html = document.documentElement;

    if (html.getAttribute("data-theme") === "light") {

        html.setAttribute("data-theme", "dark");
        themeToggle.textContent = "☀️ Light Mode";

    } else {

        html.setAttribute("data-theme", "light");
        themeToggle.textContent = "🌙 Dark Mode";
    }
});
